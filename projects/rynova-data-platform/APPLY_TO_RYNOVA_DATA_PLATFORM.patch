diff --git a/rynova/src/rynova_platform/java_bridge/compile.py b/rynova/src/rynova_platform/java_bridge/compile.py
new file mode 100644
index 00000000..1c44822c
--- /dev/null
+++ b/rynova/src/rynova_platform/java_bridge/compile.py
@@ -0,0 +1,39 @@
+"""Compile-time check for the Java backend service.
+
+Locates ``javac`` on ``PATH`` and compiles the Java sources shipped in
+``./java`` into a scratch directory.  Returns ``True`` on success.  The
+helper is shelled out via ``subprocess`` so it works with any JDK 11+
+toolchain (Adoptium, Corretto, Zulu) without depending on a build
+system.
+"""
+
+from __future__ import annotations
+
+import os
+import shutil
+import subprocess
+import tempfile
+from pathlib import Path
+
+HERE = Path(__file__).parent
+JAVA_DIR = HERE / "java"
+
+
+def java_sources() -> list[Path]:
+    return sorted(JAVA_DIR.rglob("*.java"))
+
+
+def compile_java(*, jdk: str | None = None) -> bool:
+    javac = jdk or shutil.which("javac")
+    if not javac:
+        return False
+    sources = java_sources()
+    if not sources:
+        return False
+    with tempfile.TemporaryDirectory() as out:
+        cmd = [javac, "-d", out, *[str(p) for p in sources]]
+        try:
+            subprocess.check_call(cmd, env={**os.environ, "LC_ALL": "C"})
+        except subprocess.CalledProcessError:
+            return False
+    return True
diff --git a/rynova/src/rynova_platform/java_bridge/java/com/rynova/platform/EventBus.java b/rynova/src/rynova_platform/java_bridge/java/com/rynova/platform/EventBus.java
new file mode 100644
index 00000000..40ec718c
--- /dev/null
+++ b/rynova/src/rynova_platform/java_bridge/java/com/rynova/platform/EventBus.java
@@ -0,0 +1,38 @@
+package com.rynova.platform;
+
+import java.util.List;
+import java.util.Map;
+import java.util.concurrent.ConcurrentHashMap;
+import java.util.concurrent.CopyOnWriteArrayList;
+import java.util.concurrent.atomic.AtomicLong;
+import java.util.function.Consumer;
+
+/**
+ * Tiny pub/sub for in-process events on the Java side of the platform.
+ * Mirrors {@code rynova_platform.api.event_bus.AsyncEventBus}.
+ */
+public final class EventBus {
+
+    private final Map<String, List<Consumer<Map<String, Object>>>> subscribers = new ConcurrentHashMap<>();
+    private final AtomicLong delivered = new AtomicLong();
+
+    public long delivered() {
+        return delivered.get();
+    }
+
+    public void subscribe(String topic, Consumer<Map<String, Object>> handler) {
+        subscribers.computeIfAbsent(topic, k -> new CopyOnWriteArrayList<>()).add(handler);
+    }
+
+    public int publish(String topic, Map<String, Object> payload) {
+        List<Consumer<Map<String, Object>>> handlers = subscribers.get(topic);
+        if (handlers == null) {
+            return 0;
+        }
+        for (Consumer<Map<String, Object>> handler : handlers) {
+            handler.accept(payload);
+            delivered.incrementAndGet();
+        }
+        return handlers.size();
+    }
+}
diff --git a/rynova/src/rynova_platform/java_bridge/java/com/rynova/platform/QueryService.java b/rynova/src/rynova_platform/java_bridge/java/com/rynova/platform/QueryService.java
