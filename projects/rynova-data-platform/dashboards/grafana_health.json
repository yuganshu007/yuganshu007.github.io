{
  "title": "Rynova Data Platform — Production Health",
  "schemaVersion": 38,
  "uid": "rynova-prod-health",
  "tags": ["rynova", "production", "data-platform"],
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "API p95 latency (ms)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rynova_api_latency_seconds_bucket[5m])) by (le, route)) * 1000",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "API requests / min by status",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(rynova_api_requests_total[1m])) by (status) * 60",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Kafka consumer lag",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "max(rynova_stream_lag_messages) by (topic, group)",
          "legendFormat": "{{topic}}/{{group}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Idempotent sink dedupes",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(increase(rynova_sink_dedupes_total[1h]))"
        }
      ]
    },
    {
      "id": 5,
      "title": "ETL pipeline outcomes (24h)",
      "type": "barchart",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(increase(rynova_pipeline_runs_total[24h])) by (pipeline, result)"
        }
      ]
    },
    {
      "id": 6,
      "title": "Events published / sec",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(rynova_events_published_total[1m])) by (topic)",
          "legendFormat": "{{topic}}"
        }
      ]
    }
  ]
}
